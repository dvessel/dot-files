# https://ghostty.org/docs/config.

theme = light:lightness,dark:darkness

# 2nd font-family set for CJK fallback.
font-family = Lilex Nerd Font
font-family = Apple SD Gothic Neo
font-size   = 13

window-width = 90
window-height = 30
window-padding-x = 10,0
window-padding-y = 0
window-padding-color = extend

# Centering for 1728 X 1117 given the above values.
window-position-x = 494
window-position-y = 267

window-step-resize = true

quick-terminal-position = center
quick-terminal-space-behavior = remain

macos-titlebar-style = tabs
macos-icon = blueprint

initial-window = false
mouse-hide-while-typing = true

working-directory = home
window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true

bell-features = no-attention,no-title,system,border
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
notify-on-command-finish-after = 20s

# Limit in bytes. Default 10MB, set to 500MB.
scrollback-limit = 500000000

config-file = keybinds
